<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.wellnessvalley.app">
    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
    android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
    android:maxSdkVersion="32" />
    <!-- READ_MEDIA_IMAGES removed: app uses system photo picker (one-time access),
         which does not require this permission on Android 13+ (API 33+).
         Google Play policy prohibits READ_MEDIA_IMAGES for infrequent/one-time media access. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
        <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Location permissions for attendance tracking and outdoor GPS map -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- ACCESS_BACKGROUND_LOCATION removed — foreground location is sufficient -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Usage Stats permission for device-wide screen time comparison -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Background service restart permissions -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Exact alarms for precise reminder times (wellness/reminder app category) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- ── Daily Activity Reminders ─────────────────────────────────── -->
    <!-- Exact alarms: SCHEDULE_EXACT_ALARM for Android 12 (API 31-32), requires runtime check -->
    <!-- On Android 13+ (API 33+), use inexact alarms or request SCHEDULE_EXACT_ALARM at runtime -->
    <!-- Reschedule reminders after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Wake device screen + CPU for alarm -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Vibrate device during alarm -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Run alarm sound as foreground service (keeps audio playing when app is closed).. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Show full-screen alarm popup on lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Queries for share functionality (Android 11+) -->
    <queries>
        <!-- Allow querying all apps for sharing -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND_MULTIPLE" />
            <data android:mimeType="image/*" />
        </intent>
        <!-- WhatsApp -->
        <package android:name="com.whatsapp" />
        <!-- Gmail -->
        <package android:name="com.google.android.gm" />
        <!-- Messages -->
        <package android:name="com.google.android.apps.messaging" />
        <!-- Telegram -->
        <package android:name="org.telegram.messenger" />
        <!-- Instagram -->
        <package android:name="com.instagram.android" />
        <!-- Facebook -->
        <package android:name="com.facebook.katana" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Wellness Valley"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        android:largeHeap="true">
        
        <!-- Google Services Configuration -->
        <meta-data android:name="com.google.android.gms.client_id" 
                   android:value="@string/server_client_id" />
        
        <!-- Firebase Configuration -->
        <meta-data android:name="com.google.firebase.auth.USE_EMULATOR" 
                   android:value="false" />

        <activity
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:name=".MainActivity"
            android:label="Wellness Valley"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Android App Links: open https://<host>/share/<token> directly in the app.
                 Requires /.well-known/assetlinks.json to be served from each host.
                 Each host has its own intent-filter so one failing verification
                 does not block the others. -->

            <!-- Production domain (primary — all share links target this) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="wellness-valley.vercel.app"
                      android:pathPrefix="/share/" />
            </intent-filter>

            <!-- Test / staging backend domain -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="wellness-buddy-pwa-backend-test.vercel.app"
                      android:pathPrefix="/share/" />
            </intent-filter>

            <!-- Legacy frontend domain (kept for backward compat) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="wellness-buddy-pwa-eta.vercel.app"
                      android:pathPrefix="/share/" />
            </intent-filter>

            <!-- Custom-scheme fallback (used by the web landing page and
                 debug builds before App Links verification completes). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="wellnessvalley" android:host="share" />
            </intent-filter>

            <!-- Add these intent filters for Firebase Auth redirect -->
            <!-- <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" /> -->
                <!-- Replace with your actual scheme from Firebase config -->
                <!-- <data android:scheme="wellnessbuddy" />
                <data android:host="auth" />
            </intent-filter> -->

            <!-- For Google Sign-In redirect -->
            <!-- <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="wellnessvalley" android:host="auth" />
            </intent-filter> -->
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- Background service for step counter and screen time tracking -->
        <service
            android:name=".services.GalleryMonitorService"
            android:exported="false"
            android:process=":background"
            android:foregroundServiceType="dataSync|location"
            android:stopWithTask="false" />

        <!-- Restarts GalleryMonitorService after device reboot -->
        <receiver
            android:name=".services.BootCompletedReceiver"
            android:exported="false">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- AlarmManager watchdog — restarts service if killed -->
        <receiver
            android:name=".services.ServiceAlarmReceiver"
            android:exported="false" />

        <!-- ── Daily Activity Reminder receivers ──────────────────────── -->
        <!-- Fires when an alarm triggers; shows notification + reschedules for next day -->
        <receiver
            android:name=".services.ReminderAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.wellnessvalley.app.REMINDER_WEIGHT" />
                <action android:name="com.wellnessvalley.app.REMINDER_EDUCATION" />
                <action android:name="com.wellnessvalley.app.REMINDER_BREAKFAST" />
                <action android:name="com.wellnessvalley.app.REMINDER_LUNCH" />
                <action android:name="com.wellnessvalley.app.REMINDER_DINNER" />
            </intent-filter>
        </receiver>

        <!-- Re-schedule reminders after device reboot -->
        <receiver
            android:name=".services.ReminderBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Foreground service that plays alarm sound for 60 seconds -->
        <service
            android:name=".services.AlarmSoundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Full-screen alarm popup shown on top of lock screen when alarm fires -->
        <activity
            android:name=".services.AlarmFullScreenActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Stops the alarm sound when user taps Dismiss on the notification -->
        <receiver
            android:name=".services.AlarmDismissReceiver"
            android:exported="false" />
        
    </application>
</manifest>