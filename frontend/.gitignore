
# Environment variables - NEVER commit these
.env
.env.local
.env.*.local
.env.production
.env.development

# iOS build artifacts (NEVER commit - contain embedded API keys!)
*.ipa
*.xcarchive
ios/*.xcarchive
ios/**/*.xcarchive
ios/IPA*/
ios/IPA-*/
ios/App/App/public/
ios/App/App.xcarchive/

# Android build artifacts
android/app/src/main/assets/public/
android/app/build/
android/.gradle/

# Build outputs that may contain embedded secrets
build/
dist/
out/

# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
